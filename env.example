# Banco de dados (injetado automaticamente pelo Neon via Vercel Marketplace)
DATABASE_URL=postgres://user:password@host/database?sslmode=require

# E-mail (Resend — https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL="Renovi Saúde <privacidade@renovisaude.com.br>"
TEAM_NOTIFICATION_EMAIL=privacidade@renovisaude.com.br

# Captcha (Cloudflare Turnstile — https://dash.cloudflare.com)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x0000000000000000000000
TURNSTILE_SECRET_KEY=0x0000000000000000000000000000000000000000

# Rate limit (Upstash Redis — https://console.upstash.com)
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL base do sistema
NEXT_PUBLIC_APP_BASE_URL=https://lgpd.renovisaude.com.br
